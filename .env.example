# Database Configuration
# Copy this file to .env and fill in your Aiven database credentials

DB_HOST=your-aiven-host
DB_PORT=db-port-number
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=db-name

# ---------------------------------------------------------------------------
# Google OAuth (optional – only needed for Google login)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# ---------------------------------------------------------------------------
# Ollama / Problem Assistance (optional – only needed for AI chat feature)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
